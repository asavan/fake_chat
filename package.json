{
  "name": "fake_chat",
  "version": "0.0.1",
  "private": true,
  "description": "fake_chat",
  "author": "Alex Sav",
  "main": "index.js",
  "type": "module",
  "sideEffects": false,
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "error"
    }
  },
  "scripts": {
    "start": "webpack serve --config webpack_configs/webpack.config.js --mode development",
    "android": "webpack --config webpack_configs/android.webpack.config.js --mode production",
    "build": "webpack --config webpack_configs/production.webpack.config.js --mode production",
    "style": "npx eslint . -c linters/eslint.config.js",
    "style2": "npx eslint . -c linters/eslint.config.js",
    "style:fix": "npx eslint . -c linters/eslint.config.js --fix",
    "style3": "npx stylelint --config linters/stylelint.config.js \"src/**/*.css\"",
    "style3:fix": "npx stylelint --config linters/stylelint.config.js \"src/**/*.css\" --fix",
    "test": "node --test --test-reporter dot",
    "test:verbose": "node --test",
    "test:watch": "node --test --watch",
    "test:coverage": "c8 node --test --test-reporter dot",
    "updates": "npx ncu",
    "updates:fix": "npx ncu -u && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asavan/fake_chat.git"
  },
  "homepage": "https://asavan.github.io/fake_chat/",
  "devDependencies": {
    "devdeps": "github:asavan/dev-deps#v0.0.15"
  }
}
